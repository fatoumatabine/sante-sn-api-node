# Used by docker-compose.prod.yml on the target server
IMAGE=docker.io/your-dockerhub-user/sante-sn-api-node:latest
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://postgres:change_me@db-host:5432/sante_sn?schema=public
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=https://your-frontend-domain.tld
API_BASE_URL=https://your-api-domain.tld
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@your-domain.tld
SMTP_PASS=change_me
MAIL_FROM="Sante SN <no-reply@your-domain.tld>"
PAYDUNYA_MASTER_KEY=change_me
PAYDUNYA_PRIVATE_KEY=change_me
PAYDUNYA_TOKEN=change_me
PAYDUNYA_MODE=test
PAYDUNYA_BASE_URL=https://app.paydunya.com
PAYDUNYA_CALLBACK_URL=https://your-api-domain.tld/api/v1/paiements/webhooks/paydunya
PAYDUNYA_RETURN_URL=https://your-frontend-domain.tld/patient/paiements?payment=success
PAYDUNYA_CANCEL_URL=https://your-frontend-domain.tld/patient/paiements?payment=cancelled
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
LOG_RESET_TOKEN=false
