# Used by docker-compose.prod.yml on the target server
IMAGE=docker.io/your-dockerhub-user/sante-sn-api-node:latest

NODE_ENV=production
PORT=5000

# Database URL - Neon is recommended in production
# DATABASE_URL must use Neon pooled endpoint (-pooler) for app traffic.
# DIRECT_URL must use Neon direct endpoint for Prisma migrations.
# See NEON_SETUP_GUIDE.md for detailed setup instructions.
DATABASE_URL=postgresql://user:change_me@ep-xxx-pooler.region.aws.neon.tech/sante_sn?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://user:change_me@ep-xxx.region.aws.neon.tech/sante_sn?sslmode=require&channel_binding=require

JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_me
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=https://your-frontend-domain.tld
FRONTEND_URLS=https://your-custom-domain.tld,https://your-preview-domain.vercel.app
ALLOW_VERCEL_PREVIEW_ORIGINS=false
RUN_DB_SEED_ON_START=false

API_BASE_URL=https://your-api-domain.tld

RESET_PASSWORD_TOKEN_TTL_MINUTES=30
LOG_RESET_TOKEN=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@your-domain.tld
SMTP_PASS=change_me
MAIL_FROM="Sante SN <no-reply@your-domain.tld>"

OPENAI_API_KEY=change_me
OPENAI_TRIAGE_MODEL=gpt-5.4
OPENAI_TRIAGE_FALLBACK=false

PAYDUNYA_MASTER_KEY=change_me
PAYDUNYA_PRIVATE_KEY=change_me
PAYDUNYA_TOKEN=change_me
PAYDUNYA_MODE=test
PAYDUNYA_BASE_URL=https://app.paydunya.com
PAYDUNYA_CALLBACK_URL=https://your-api-domain.tld/api/v1/paiements/webhooks/paydunya
PAYDUNYA_RETURN_URL=https://your-frontend-domain.tld/patient/paiements?payment=success
PAYDUNYA_CANCEL_URL=https://your-frontend-domain.tld/patient/paiements?payment=cancelled
PAYDUNYA_STORE_NAME=Sante SN
PAYDUNYA_STORE_TAGLINE=Paiement des consultations
PAYMENT_SIMULATION_ONLINE=false
