# Server
NODE_ENV=development
PORT=5000

# Database
# Local PostgreSQL:
# DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/sante_sn?schema=public"
# DIRECT_URL="postgresql://postgres:your_password_here@localhost:5432/sante_sn?schema=public"
#
# Neon pooled connection for the running app:
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/sante_sn?sslmode=require&channel_binding=require"
# Neon direct connection for Prisma migrations/introspection:
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/sante_sn?sslmode=require&channel_binding=require"
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/sante_sn?schema=public"
DIRECT_URL="postgresql://postgres:your_password_here@localhost:5432/sante_sn?schema=public"
# Prisma query logs (set true only for SQL debugging)
PRISMA_LOG_QUERIES=false

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Password reset
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
# Set to true to expose reset-link debug info in local or troubleshooting environments
LOG_RESET_TOKEN=false

# CORS
FRONTEND_URL=https://sant-sn-indol.vercel.app/
FRONTEND_URLS=
ALLOW_VERCEL_PREVIEW_ORIGINS=false
RUN_DB_SEED_ON_START=false

# Email (optional - for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
MAIL_FROM="Santé SN <no-reply@santesn.com>"

# AI triage (optional - fallback local is enabled by default unless OPENAI_TRIAGE_FALLBACK=false)
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-5.4
OPENAI_TRIAGE_FALLBACK=true
