# Server
NODE_ENV=development
PORT=5000

# Database (Local PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/sante_sn?schema=public"
# Prisma query logs (set true only for SQL debugging)
PRISMA_LOG_QUERIES=false

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Password reset
RESET_PASSWORD_TOKEN_TTL_MINUTES=30
# Set to true only for local debugging of reset link generation
LOG_RESET_TOKEN=false

# CORS
FRONTEND_URL=http://localhost:8081

# Email (optional - for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
MAIL_FROM="Santé SN <no-reply@santesn.com>"
